ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
PAPER_TRADING=true
# Optional on Render when using a persistent disk (example: /data)
DATA_DIR=
AUTO_EXPAND_UNIVERSE_WITH_MOVERS=true
UNIVERSE_MOVER_TOP=100
UNIVERSE_MAX_TICKERS=300
SCAN_MIN_BARS=5
OBSERVATION_ENABLED=true
OBSERVATION_END_TIME=10:00
ENABLE_HTF_CONFIRM=false
HTF_TIMEFRAME=15m
HTF_LOOKBACK_BARS=30
ENABLE_ORDER_FLOW_FILTER=false
MIN_FLOW_SCORE=0.05
RSI_EARLY_MIN_PERIOD=5
ENABLE_NEWS_EVENT_BLOCK=true
NEWS_LOOKBACK_MINUTES=90
NEWS_BLOCK_KEYWORDS=earnings,guidance,sec,investigation,lawsuit,fda,downgrade,upgrade,cpi,fomc,fed
ENABLE_HISTORICAL_REGIME_SCORE=true
MIN_HISTORICAL_REGIME_SCORE=2.0
ENABLE_SIGNAL_SCORING=true
MIN_SIGNAL_SCORE=3.5
RISK_PER_TRADE_PCT=0.01
MAX_POSITION_SIZE_USD=700
DRAWDOWN_REDUCE_AFTER_CONSEC_LOSSES=2
DRAWDOWN_SIZE_MULTIPLIER=0.5
WEEKLY_LOSS_LIMIT_USD=900
MAX_ENTRY_SLIPPAGE_PCT=2.0
MAX_FILL_SLIPPAGE_PCT=5.0
MAX_HOLD_MINUTES=75
ENABLE_VIX_GUARD=true
VIX_MIN=13
VIX_MAX=80
RVOL_MIN=1.0
IV_RANK_MAX=75
HEARTBEAT_SECONDS=300
CLOSED_MIN_SLEEP_SECONDS=60
CLOSED_MAX_SLEEP_SECONDS=300
DISCORD_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
ALERT_COOLDOWN_SECONDS=300
# Comma-separated ET dates to block new entries (example: FOMC/CPI days)
NEWS_BLOCK_DATES_ET=2026-04-10
