ALPACA_API_KEY=your_paper_alpaca_api_key_here
ALPACA_SECRET_KEY=your_paper_alpaca_secret_key_here
PAPER_TRADING=true
# Required when PAPER_TRADING=true: your LIVE account API keys, used ONLY for
# options contract/quote lookups (Alpaca's live endpoint rejects paper keys).
# All orders are still placed through the paper account above.
ALPACA_LIVE_API_KEY=your_live_alpaca_api_key_here
ALPACA_LIVE_SECRET_KEY=your_live_alpaca_secret_key_here
DASHBOARD_CONTROL_TOKEN=replace_with_a_strong_random_token
# Optional on Render when using a persistent disk (example: /data)
DATA_DIR=
AUTO_EXPAND_UNIVERSE_WITH_MOVERS=true
UNIVERSE_MOVER_TOP=100
UNIVERSE_MAX_TICKERS=300
SCAN_MIN_BARS=5
ENABLE_OPENING_ENTRY_RELAX=true
OPENING_ENTRY_RELAX_MINUTES=7
OBSERVATION_ENABLED=true
OBSERVATION_END_TIME=10:00
ENABLE_CATALYST_MODE=true
CATALYST_WINDOW_MINUTES=90
CATALYST_INDEX_5M_MOVE_PCT=1.2
CATALYST_BREADTH_MOVE_PCT=1.0
CATALYST_BREADTH_MIN_COUNT=6
CATALYST_RELAXED_RVOL_MIN=0.6
CATALYST_DISABLE_RSI=true
CATALYST_ALLOW_IV_FALLBACK=true
CATALYST_RELAXED_IV_RANK_MAX=90
CATALYST_RELAXED_MIN_SIGNAL_SCORE=2.5
ENABLE_HTF_CONFIRM=false
HTF_TIMEFRAME=15m
HTF_LOOKBACK_BARS=30
ENABLE_ORDER_FLOW_FILTER=false
MIN_FLOW_SCORE=0.05
RSI_EARLY_MIN_PERIOD=5
ENABLE_NEWS_EVENT_BLOCK=true
NEWS_LOOKBACK_MINUTES=90
NEWS_BLOCK_KEYWORDS=earnings,guidance,sec,investigation,lawsuit,fda,downgrade,upgrade,cpi,fomc,fed
ENABLE_HISTORICAL_REGIME_SCORE=true
MIN_HISTORICAL_REGIME_SCORE=2.0
ENABLE_SIGNAL_SCORING=true
MIN_SIGNAL_SCORE=3.5
RISK_PER_TRADE_PCT=0.01
MAX_POSITION_SIZE_USD=700
DRAWDOWN_REDUCE_AFTER_CONSEC_LOSSES=2
DRAWDOWN_SIZE_MULTIPLIER=0.5
WEEKLY_LOSS_LIMIT_USD=900
MAX_ENTRY_SLIPPAGE_PCT=2.0
MAX_FILL_SLIPPAGE_PCT=5.0
MAX_HOLD_MINUTES=75
ENABLE_VIX_GUARD=true
VIX_MIN=13
VIX_MAX=80
RVOL_MIN=0.6
OPENING_RVOL_MIN=0.05
ROC_BULL_MIN=0.05
ROC_BEAR_MAX=-0.05
RSI_CALL_MIN=45
RSI_CALL_MAX=90
RSI_PUT_MIN=10
RSI_PUT_MAX=55
IV_RANK_MAX=75
MIN_OPTION_OPEN_INTEREST=25
MIN_OPTION_DAILY_VOLUME=5
MAX_OPTION_SPREAD_PCT=35
ENABLE_OPTION_LIQUIDITY_RELAX=true
# Keep false for paper-only setup; set true only if your key/account explicitly
# supports option contracts on live endpoint and you want fallback.
OPTION_CONTRACTS_ALLOW_LIVE_FALLBACK=false
ENABLE_ENTRY_CONFIRMATION=true
ENTRY_CONFIRM_BARS=2
ENTRY_CONFIRM_BYPASS_MIN_SIGNAL_SCORE=7.5
MIN_DTE_TRADING_DAYS=1
OPTION_FORCE_EXIT_DAYS_BEFORE_EXPIRY=1
OPTION_EXPIRY_EXIT_TIME=15:00
HEARTBEAT_SECONDS=300
CLOSED_MIN_SLEEP_SECONDS=60
CLOSED_MAX_SLEEP_SECONDS=300
ENTRY_ORDER_STATUS_WAIT_SECONDS=8
ENTRY_RETRY_STATUS_WAIT_SECONDS=5
ENTRY_MARKET_FALLBACK_WAIT_SECONDS=3
TRADES_MAX_ROWS=5000
DISCORD_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
ALERT_COOLDOWN_SECONDS=300
REDIS_URL=
AUTOBOTT_REDIS_PREFIX=autobott
# Comma-separated ET dates to block new entries (example: FOMC/CPI days)
NEWS_BLOCK_DATES_ET=2026-04-10
